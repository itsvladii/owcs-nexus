---
export const prerender = false;
import BaseLayout from "../layouts/BaseLayout.astro";
import RankingsTable from "../components/eloComps/RankTable.svelte";
import LateralTab from "../components/eloComps/LateralTab.svelte";
import RankingOOBE from "../components/eloComps/OOBEComp.svelte";
import RecentMatches from "../components/eloComps/RecentMatches.svelte";
import { supabase } from "../lib/contentScripts/supabase";
import { Image } from "astro:assets";

//1. fetch data from Supabase
const { data: rankings } = await supabase
    .from("rankings")
    .select("*")
    .order("rating", { ascending: false });

const { data: statsData } = await supabase
    .from("global_stats")
    .select("*")
    .single();

const stats = {
    biggestMover: statsData?.biggest_mover || null,
    longestReign: statsData?.longest_reign || null,
    biggestUpsets: statsData?.biggest_upsets || [],
};

const { data: processedMatches } = await supabase
    .from("processed_matches")
    .select("*");

//cache the output for 10 minutes, but allow stale data to be served while revalidating for 30s
Astro.response.headers.set(
    "Cache-Control",
    "public, s-maxage=600, stale-while-revalidate=30",
);
const teamMap = new Map();
//check if rankings exist before iterating to avoid runtime errors in case of empty data
if (rankings) {
    rankings.forEach((t) => {
        teamMap.set(t.name.toLowerCase(), t);
    });
}

function getLocalTeam(apiName: string) {
    if (!apiName) return undefined;
    return teamMap.get(apiName.toLowerCase());
}

//formatting the last updated date in a more readable way
const lastUpdated = new Date().toLocaleDateString("en-US", {
    month: "long",
    day: "numeric",
    hour: "numeric",
    timeZoneName: "short",
    year: "numeric",
});

//formatting team details (logos for dark mode and light mode and name)
function getTeamProps(team: {
    name: string;
    logo?: string;
    logoDark?: string;
}) {
    const localTeam = getLocalTeam(team.name);
    const hasPage = !!localTeam;

    const logo = team.logoDark || team.logo;

    return { localTeam, hasPage, logo };
}

//formatting team data for the component
const tableData: RankingTeam[] = rankings.map((team, index) => {
    const localData = getLocalTeam(team.name);
    return {
        rank: index + 1,
        name: team.name,
        slug: localData?.id || team.name.toLowerCase().replace(/\s+/g, "-"),
        rating: Math.round(team.rating),
        wins: team.wins,
        losses: team.losses,
        region: team.region || "Unknown",
        logo: team.logo_dark || team.logo,
        isPartner: team.isPartner || false,
        hasPage: !!localData,
        history: team.history,
        tournaments: team.tournaments,
        rankDelta: team.rank_delta,
        form: team.form,
    };
});

//creating a map for quick access to team logos and slugs in the RecentMatches component
const teamInfoMap: Record<string, { logo?: string; slug?: string }> = {};
tableData.forEach((t) => {
    teamInfoMap[t.name.toLowerCase()] = { logo: t.logo, slug: t.slug };
});

//calculating regional averages and trends for the LateralTab component
const regions = ["Korea", "North America", "EMEA", "China", "Japan", "Pacific"];
const regionalAverages = regions
    .map((reg) => {
        const regionalTeams = rankings
            .filter((t) => t.region === reg)
            .sort((a, b) => b.rating - a.rating)
            .slice(0, 5);

        const avg =
            regionalTeams.length > 0
                ? Math.round(
                      regionalTeams.reduce((acc, t) => acc + t.rating, 0) /
                          regionalTeams.length,
                  )
                : 1200;

        //sum the ELO change from the last 24h of these specific top 5 teams
        const change =
            regionalTeams.reduce((acc, t) => {
                const lastMatch = processedMatches.find(
                    (m) =>
                        (m.team_a === t.name || m.team_b === t.name) &&
                        new Date().getTime() - new Date(m.date).getTime() <
                            86400000,
                );
                const change = lastMatch
                    ? lastMatch.team_a === t.name
                        ? lastMatch.elo_change_a
                        : lastMatch.elo_change_b
                    : 0;
                return acc + (change || 0);
            }, 0) / (regionalTeams.length || 1);

        return { name: reg, avg, trend: Math.round(change) };
    })
    .sort((a, b) => b.avg - a.avg);
---

<BaseLayout title="Team Global Standings | OWCS Nexus">
    <header
        class="relative w-full h-[60vh] overflow-hidden bg-[#080808] flex items-end pb-20"
    >
        <div class="absolute inset-0 z-0">
            <Image
                src="https://live.staticflickr.com/65535/54956871956_239e2d7ec1_k.jpg"
                alt="Header Background"
                width={1920}
                height={1080}
                format="webp"
                quality="high"
                class="w-full h-full object-cover opacity-20 grayscale parallax-video"
            />
            <div
                class="absolute inset-0 bg-gradient-to-t from-[#080808] via-transparent to-transparent"
            >
            </div>
        </div>

        <div class="max-w-[1600px] mx-auto px-6 w-full relative z-10">
            <!-- Eyebrow: monospace metadata, no heavy badge -->
            <div class="flex items-center gap-4 mb-5">
                <span
                    class="w-1.5 h-1.5 rounded-full bg-[#085FFF] shadow-[0_0_8px_#085FFF]"
                ></span>
                <span
                    class="font-mono text-[10px] text-white/40 uppercase tracking-[0.4em]"
                >
                    OWCS Season 3
                </span>
                <span
                    class="font-mono text-[10px] text-white/20 uppercase tracking-[0.3em]"
                    >·</span
                >
                <span
                    class="font-mono text-[10px] text-white/25 uppercase tracking-[0.3em]"
                >
                    Last updated: {lastUpdated}
                </span>
            </div>

            <!-- Title: white, no blue fill on "STANDINGS" — use weight/size contrast instead -->
            <h1
                class="text-[clamp(4rem,12vw,10rem)] font-title uppercase italic text-white leading-[0.75] tracking-tighter"
            >
                Team Global <br />
                <span class="text-[#085FFF]">Standings</span>
            </h1>
        </div>
    </header>

    <RankingOOBE client:load />

    <RecentMatches
        matches={processedMatches ?? []}
        teamInfo={teamInfoMap}
        client:load
    />

    <main class="max-w-[1600px] mx-auto px-6 py-20 bg-[#080808]">
        <!-- Stat highlight cards: Biggest Mover + Longest Reign -->
        {
            (stats.biggestMover || stats.longestReign) && (
                <div class="flex flex-wrap gap-4 mb-12">
                    {stats.biggestMover && (
                        <div class="flex items-center gap-4 border border-white/5 bg-white/[0.02] px-5 py-4 min-w-[220px]">
                            <div class="w-[2px] self-stretch bg-[#085FFF]" />
                            <div class="flex flex-col gap-1">
                                <span class="font-mono text-[9px] uppercase tracking-[0.3em] text-[#085FFF]">
                                    Biggest Mover
                                </span>
                                <span class="font-title uppercase italic text-white text-lg leading-none tracking-tight">
                                    {stats.biggestMover.name}
                                </span>
                                <span class="font-mono text-xs text-[#085FFF]">
                                    + {stats.biggestMover.gain} pts
                                </span>
                            </div>
                        </div>
                    )}
                    {stats.longestReign && (
                        <div class="flex items-center gap-4 border border-white/5 bg-white/[0.02] px-5 py-4 min-w-[220px]">
                            <div class="w-[2px] self-stretch bg-[#FF7FDE]" />
                            <div class="flex flex-col gap-1">
                                <span class="font-mono text-[9px] uppercase tracking-[0.3em] text-[#FF7FDE]">
                                    Longest Reign
                                </span>
                                <span class="font-title uppercase italic text-white text-lg leading-none tracking-tight">
                                    {stats.longestReign.name}
                                </span>
                                <span class="font-mono text-xs text-[#FF7FDE]">
                                    {stats.longestReign.days} days at #1
                                </span>
                            </div>
                        </div>
                    )}
                </div>
            )
        }

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">
            <div class="lg:col-span-8 space-y-2">
                <RankingsTable
                    teams={tableData}
                    matches={processedMatches}
                    client:only="svelte"
                />
            </div>

            <aside class="lg:col-span-4 space-y-8">
                <LateralTab regionalAverages={regionalAverages} client:load />
            </aside>
        </div>
    </main>
</BaseLayout>
