---
import owcs10 from "../content/img/owcs_10.jpg";
import owcs16 from "../content/img/owcs_16.jpg";
import owcs1 from "../content/img/owcs_1.jpg";
import BaseLayout from "../layouts/BaseLayout.astro";
import LiveMatchCard from "../components/homeComps/LiveMatchCard.svelte";
import { Image } from "astro:assets";
import { supabase } from "../lib/contentScripts/supabase";

const { count: totalMatches } = await supabase
    .from("processed_matches")
    .select("*", { count: "exact", head: true });

const heroClipIDs = [
    "crazy_raccoons_clip",
    "wbg_clip",
    "vl_clip",
    "vp_clip",
    "aq_clip",
    "ntmp_clip",
    "tm_clip",
    "t1_clip",
    "tl_clip",
    "agg_clip",
    "cc_clip",
    "gk_clip",
    "ssg_clip",
    "tf_clip",
];

const videoBaseUrl = `https://res.cloudinary.com/dm1bfprgq/video/upload/vc_h264,w_1080,f_auto,q_auto:eco,br_2500k/v1764453427`;
const heroClipUrls = heroClipIDs.map((id) => `${videoBaseUrl}/${id}.mp4`);
const startVideo = heroClipUrls[0];
---

<BaseLayout title="Home" fullWidth={true}>
    <div
        class="relative h-[92vh] w-full overflow-hidden bg-[#080808] bg-cover bg-center"
        style={`background-image: url(${owcs1});`}
    >
        <div
            id="video-container"
            class="absolute inset-0"
            data-clips={JSON.stringify(heroClipUrls)}
        >
            <video
                id="player-1"
                class="absolute inset-0 w-full h-full object-cover opacity-0 transition-opacity duration-500"
                src={startVideo}
                autoplay
                muted
                playsinline
                loop></video>
            <video
                id="player-2"
                class="absolute inset-0 w-full h-full object-cover opacity-0 transition-opacity duration-500"
                muted
                playsinline></video>
        </div>

        <div
            class="absolute inset-0 z-10 pointer-events-none bg-[radial-gradient(circle_at_center,_transparent_0%,_#080808_90%)] opacity-60"
        >
        </div>
        <div
            class="absolute inset-0 z-10 pointer-events-none bg-gradient-to-t from-[#080808] via-transparent to-transparent"
        >
        </div>

        <div
            class="absolute inset-0 z-20 flex flex-col justify-end px-6 md:px-16 pb-16"
        >
            <div class="flex items-center gap-3 mb-4">
                <span
                    class="bg-[#085FFF] text-black font-black text-[10px] px-2 py-0.5 uppercase italic shadow-[0_0_10px_#085FFF]"
                    >Online</span
                >
                <span
                    class="font-mono text-[10px] text-white/50 uppercase tracking-[0.3em]"
                    >OWCS Season 3 · {totalMatches} Matches</span
                >
            </div>

            <h1
                class="font-title text-[clamp(4rem,15vw,10rem)] uppercase italic leading-[0.75] text-white tracking-tighter mb-8"
            >
                OWCS<br />
                <span class="text-[#085FFF]">NEXUS</span>
            </h1>

            <div class="flex gap-4">
                <a
                    href="/rankings"
                    class="bg-white text-black px-8 py-3 font-title uppercase italic hover:bg-[#085FFF] transition-colors"
                    >Global Standings</a
                >
                <a
                    href="/stats"
                    class="border border-white/20 text-white px-8 py-3 font-title uppercase italic hover:bg-white/10 transition-all"
                    >Meta Report</a
                >
            </div>
        </div>
    </div>

    <div class="w-full bg-[#080808] border-y border-white/5">
        <LiveMatchCard client:load />
    </div>

    <div
        class="w-full py-4 bg-[#080808] border-b border-white/5 flex justify-between px-10"
    >
        <span
            class="font-mono text-[10px] uppercase tracking-[0.5em] text-white/20"
        ></span>
        <span
            class="font-mono text-[10px] uppercase tracking-[0.5em] text-white/20"
        ></span>
    </div>

    <main class="w-full bg-[#080808]">
        <div
            class="flex flex-col lg:flex-row w-full h-screen lg:h-[70vh] border-b border-white/5"
        >
            <a
                href="/rankings"
                class="flex-1 relative group overflow-hidden border-r border-white/5"
            >
                <Image
                    src={owcs10}
                    alt="Rankings"
                    format="webp"
                    class="absolute inset-0 w-full h-full object-cover grayscale opacity-30 group-hover:opacity-50 transition-all duration-700 scale-105 group-hover:scale-110"
                />
                <div
                    class="absolute left-0 top-0 w-2 h-full bg-[#085FFF] z-30 shadow-[4px_0_15px_rgba(8,95,255,0.4)]"
                >
                </div>

                <div
                    class="absolute inset-0 bg-gradient-to-t from-[#080808] via-transparent to-transparent z-10"
                >
                </div>

                <div
                    class="absolute inset-0 flex flex-col justify-end p-12 md:p-20 z-20"
                >
                    <h2
                        class="font-title text-[clamp(3rem,8vw,6rem)] uppercase italic leading-[0.8] text-white mb-6 tracking-tighter"
                    >
                        Team Global<br /><span class="text-[#085FFF]"
                            >Standings</span
                        >
                    </h2>
                    <p
                        class="font-mono text-xs text-white/40 uppercase tracking-[0.4em] max-w-md"
                    >
                        (Un)official ELO rankings based on official OWCS match
                        results.
                    </p>
                </div>
            </a>

            <a href="/stats" class="flex-1 relative group overflow-hidden">
                <Image
                    src={owcs16}
                    alt="Meta"
                    format="webp"
                    class="absolute inset-0 w-full h-full object-cover grayscale opacity-30 group-hover:opacity-50 transition-all duration-700 scale-105 group-hover:scale-110"
                />
                <div
                    class="absolute left-0 top-0 w-2 h-full bg-violet-700 z-30 shadow-[4px_0_15px_rgba(139,92,246,0.4)]"
                >
                </div>

                <div
                    class="absolute inset-0 bg-gradient-to-t from-[#080808] via-transparent to-transparent z-10"
                >
                </div>

                <div
                    class="absolute inset-0 flex flex-col justify-end p-12 md:p-20 z-20"
                >
                    <h2
                        class="font-title text-[clamp(3rem,8vw,6rem)] uppercase italic leading-[0.8] text-white mb-6 tracking-tighter"
                    >
                        The Meta<br /><span class="text-violet-700">Report</span
                        >
                    </h2>
                    <p
                        class="font-mono text-xs text-white/40 uppercase tracking-[0.4em] max-w-md"
                    >
                        Hero ban rate stats, sorted by region and teams.
                    </p>
                </div>
            </a>
        </div>
    </main>
</BaseLayout>

<script>
    function initVideoEngine() {
        const container = document.getElementById("video-container");
        const p1 = document.getElementById("player-1") as HTMLVideoElement;
        const p2 = document.getElementById("player-2") as HTMLVideoElement;
        if (!container || !p1 || !p2) return;

        // Pick the right resolution based on screen width
        const isMobile = window.innerWidth < 768;
        const clips = JSON.parse(
            container.dataset[isMobile ? "clipsMob" : "clips"] || "[]",
        );
        const posters = JSON.parse(container.dataset.posters || "[]");
        if (clips.length === 0) return;

        let activePlayer = p1;
        let standbyPlayer = p2;

        // Client-side random start — fixes Vercel build-time caching issue
        const startIdx = Math.floor(Math.random() * clips.length);
        let currentClipIdx = startIdx;

        // Always set the random clip (even if idx 0, we still need the canplay handler)
        p1.src = clips[startIdx];
        p1.poster = posters[startIdx] ?? "";
        p1.load();

        // Only fade in once the chosen clip is actually ready — eliminates the flash
        p1.addEventListener(
            "canplay",
            () => {
                p1.play().catch(() => {});
                p1.style.opacity = "0.5";
            },
            { once: true },
        );

        // Start preloading next clip after current one has had time to buffer
        setTimeout(() => prepareNextClip(), 4000);

        function prepareNextClip() {
            let nextIdx = currentClipIdx;
            while (nextIdx === currentClipIdx && clips.length > 1) {
                nextIdx = Math.floor(Math.random() * clips.length);
            }
            standbyPlayer.src = clips[nextIdx];
            standbyPlayer.poster = posters[nextIdx] ?? "";
            standbyPlayer.load();
            currentClipIdx = nextIdx;
        }

        function switchPlayer() {
            standbyPlayer
                .play()
                .then(() => {
                    // Crossfade
                    standbyPlayer.style.opacity = "0.5";
                    activePlayer.style.opacity = "0";

                    // Swap roles
                    const temp = activePlayer;
                    activePlayer = standbyPlayer;
                    standbyPlayer = temp;

                    // Prepare next after transition settles
                    setTimeout(() => {
                        standbyPlayer.pause();
                        standbyPlayer.src = ""; // free memory
                        prepareNextClip();
                    }, 1200);
                })
                .catch((e) => console.log("Playback failed:", e));
        }

        p1.onended = () => {
            if (activePlayer === p1) switchPlayer();
        };
        p2.onended = () => {
            if (activePlayer === p2) switchPlayer();
        };
    }

    document.addEventListener("astro:page-load", initVideoEngine);

    // Add this inside your script tag in index.astro
    document.addEventListener("scroll", () => {
        const video = document.getElementById("video-container");
        if (video) {
            let scrollValue = window.scrollY;
            // Move the video at 40% of the scroll speed
            video.style.transform = `translateY(${scrollValue * 0.4}px)`;
        }
    });
</script>
