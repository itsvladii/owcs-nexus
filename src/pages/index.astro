---
import owcs10 from "../content/img/owcs_10.jpg";
import BaseLayout from "../layouts/BaseLayout.astro";
import LiveMatchCard from "../components/homeComps/LiveMatchCard.svelte";
import RecentMatches from "../components/eloComps/RecentMatches.svelte";
import { Image } from "astro:assets";
import { supabase } from "../lib/contentScripts/supabase";

const { data: topTeamsRaw } = await supabase
    .from("rankings")
    .select("name, rating, region, logo, logo_dark, wins, losses")
    .order("rating", { ascending: false })
    .limit(5);

const { data: globalStats } = await supabase
    .from("global_stats")
    .select("last_synced_at")
    .eq("id", 1)
    .single();

const { count: totalMatches } = await supabase
    .from("processed_matches")
    .select("*", { count: "exact", head: true });

const topTeams = topTeamsRaw ?? [];

const REGION_COLORS: Record<string, string> = {
    Korea: "#6eff18",
    "North America": "#823bf2",
    EMEA: "#d4e800",
    Pacific: "#00c8ff",
    China: "#ff6a00",
    Japan: "#ec0201",
};

const lastUpdated = globalStats?.last_synced_at
    ? new Date(globalStats.last_synced_at).toLocaleDateString("en-US", {
          month: "short",
          day: "numeric",
          year: "numeric",
      })
    : null;

const heroClipIDs = [
    "crazy_raccoons_clip","wbg_clip","vl_clip","vp_clip","aq_clip",
    "ntmp_clip","tm_clip","t1_clip","tl_clip","agg_clip",
    "cc_clip","gk_clip","ssg_clip","tf_clip",
];

const videoBaseUrl = `https://res.cloudinary.com/dm1bfprgq/video/upload/f_mp4,vc_h264,w_1080,q_auto:eco,br_2500k/v1764453427`;
const heroClipUrls = heroClipIDs.map((id) => `${videoBaseUrl}/${id}.mp4`);
const startVideo = heroClipUrls[Math.floor(Math.random() * heroClipUrls.length)];
---

<BaseLayout title="Home" fullWidth={true}>

  <!-- ══════════════════════════════════════════
       HERO — full viewport, bottom-left text
  ══════════════════════════════════════════ -->
  <div class="relative h-screen w-full overflow-hidden bg-neutral-950">

    <!-- Video background -->
    <div id="video-container" class="absolute inset-0" data-clips={JSON.stringify(heroClipUrls)}>
      <video id="player-1"
        class="absolute inset-0 w-full h-full object-cover opacity-50 transition-opacity duration-1000"
        src={startVideo} autoplay muted playsinline></video>
      <video id="player-2"
        class="absolute inset-0 w-full h-full object-cover opacity-0 transition-opacity duration-1000"
        muted playsinline preload="none"></video>
    </div>

    <!-- Subtle grid overlay -->
    <div class="absolute inset-0 z-10 pointer-events-none opacity-10"
      style="background-image: linear-gradient(rgba(255,255,255,0.08) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.08) 1px, transparent 1px); background-size: 60px 60px;"></div>

    <!-- Gradients: left→dark for text legibility, bottom→dark for content bleed -->
    <div class="absolute inset-0 z-10 pointer-events-none"
      style="background: linear-gradient(to right, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.4) 50%, transparent 100%);"></div>
    <div class="absolute inset-0 z-10 pointer-events-none"
      style="background: linear-gradient(to top, #0a0a0a 0%, rgba(10,10,10,0.6) 25%, transparent 60%);"></div>

    <!-- Hero text — bottom left editorial style -->
    <div class="absolute bottom-0 left-0 z-20 px-8 md:px-16 pb-20 max-w-3xl">

      <!-- Status pill -->
      <div class="flex items-center gap-2 mb-6">
        <span class="flex items-center gap-2 font-mono text-[10px] uppercase tracking-[0.25em] text-neutral-400">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
          </span>
          Live · OWCS Season 3
        </span>
        {lastUpdated && (
          <span class="font-mono text-[10px] text-neutral-600 uppercase tracking-widest">
            · Updated {lastUpdated}
          </span>
        )}
      </div>

      <!-- Main title -->
      <h1 class="font-title text-[clamp(3.5rem,10vw,7rem)] uppercase leading-[0.9] text-white tracking-tighter mb-6"
        style="text-shadow: 0 2px 40px rgba(0,0,0,0.8);">
        OWCS<br/>
        <span class="text-neutral-500">Nexus</span>
      </h1>

      <!-- Descriptor -->
      <p class="font-mono text-sm text-neutral-400 uppercase tracking-[0.15em] max-w-sm leading-relaxed">
        Power rankings · Ban analytics ·<br/>
        <span class="text-white">All of OWCS, live.</span>
      </p>

      <!-- CTA row -->
      <div class="flex items-center gap-3 mt-8">
        <a href="/rankings"
          class="px-5 py-2.5 bg-white text-black font-mono text-xs uppercase tracking-widest rounded-lg hover:bg-neutral-200 transition-colors font-bold">
          View Rankings
        </a>
        <a href="/stats"
          class="px-5 py-2.5 border border-neutral-700 text-neutral-300 font-mono text-xs uppercase tracking-widest rounded-lg hover:border-neutral-500 hover:text-white transition-all">
          Meta Report
        </a>
      </div>
    </div>

    <!-- Top-right: live stats floating in hero -->
    <div class="absolute top-8 right-8 z-20 hidden lg:flex flex-col items-end gap-3">
      <div class="flex items-center gap-6 font-mono text-[10px] uppercase tracking-widest text-neutral-500">
        {totalMatches && (
          <span><span class="text-white font-bold text-sm">{totalMatches}</span> Matches</span>
        )}
        <span><span class="text-white font-bold text-sm">{topTeams.length > 0 ? '6' : '—'}</span> Regions</span>
        <span><span class="text-white font-bold text-sm">1</span> League</span>
      </div>
    </div>

  </div>

  <!-- ══════════════════════════════════════════
       LIVE TICKER — bleeds directly from hero
  ══════════════════════════════════════════ -->
  <div class="w-full bg-neutral-950">
    <LiveMatchCard client:load />
  </div>


  <!-- ══════════════════════════════════════════
       MAIN EDITORIAL GRID
  ══════════════════════════════════════════ -->
  <div class="max-w-7xl mx-auto px-6 md:px-16 py-16">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-px bg-neutral-900 rounded-2xl overflow-hidden border border-neutral-900">

      <!-- ── LEFT: RANKINGS FEATURE CARD (col 1-7) ── -->
      <a href="/rankings"
        class="lg:col-span-7 relative overflow-hidden bg-neutral-950 group min-h-[520px] flex flex-col justify-end p-8 md:p-10">

        <!-- Photo background -->
        <div class="absolute inset-0 z-0">
          <Image
            src={owcs10}
            alt="OWCS Match"
            width={1200} height={800}
            format="webp" quality="mid" loading="eager"
            class="w-full h-full object-cover object-[center_35%] opacity-70 transition-all duration-700 group-hover:opacity-50 group-hover:scale-[1.02]"
          />
          <div class="absolute inset-0"
            style="background: linear-gradient(to top, #050505 0%, rgba(5,5,5,0.7) 40%, transparent 100%);"></div>
          <div class="absolute inset-0"
            style="background: linear-gradient(to right, rgba(5,5,5,0.5) 0%, transparent 60%);"></div>
        </div>

        <!-- Top-left category label -->
        <div class="absolute top-8 left-8 z-10 flex items-center gap-2">
          <span class="w-1.5 h-1.5 rounded-full bg-red-500 animate-pulse"></span>
          <span class="font-mono text-[10px] uppercase tracking-[0.25em] text-red-400">Live Leaderboard</span>
        </div>

        <!-- Content -->
        <div class="relative z-10">
          <div class="flex items-end justify-between mb-6">
            <h2 class="font-title text-[clamp(2rem,5vw,3.5rem)] uppercase leading-none text-white tracking-tight">
              Team Global<br/>Standings
            </h2>
            <!-- Arrow -->
            <svg class="w-8 h-8 text-neutral-600 group-hover:text-white group-hover:translate-x-1 group-hover:-translate-y-1 transition-all duration-300 mb-1"
              fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 17L17 7M17 7H7M17 7v10"/>
            </svg>
          </div>
          <p class="font-mono text-xs text-neutral-500 uppercase tracking-widest max-w-sm leading-relaxed">
            ELO-based power rankings across all six OWCS regions, constantly updated.
          </p>
        </div>
      </a>

      <!-- ── RIGHT COLUMN (col 8-12) ── -->
      <div class="lg:col-span-5 flex flex-col divide-y divide-neutral-900">

        <!-- TOP 5 TEAMS -->
        <a href="/rankings"
          class="group bg-neutral-950 p-6 md:p-8 hover:bg-neutral-900/50 transition-colors flex-1">
          <div class="flex items-center justify-between mb-5">
            <p class="font-mono text-[10px] uppercase tracking-[0.25em] text-neutral-500">Power Rankings</p>
            <svg class="w-3.5 h-3.5 text-neutral-700 group-hover:text-neutral-400 transition-colors"
              fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17L17 7M17 7H7M17 7v10"/>
            </svg>
          </div>

          <div class="space-y-3">
            {topTeams.map((team, i) => {
              const color = REGION_COLORS[team.region] ?? '#525252';
              const maxRating = topTeams[0]?.rating ?? 1;
              const barWidth = Math.round((team.rating / maxRating) * 100);
              return (
                <div class="group/row relative">
                  <!-- Rating bar behind row -->
                  <div class="absolute inset-0 rounded-lg opacity-0 group-hover/row:opacity-100 transition-opacity"
                    style={`background: ${color}08`}></div>
                  <div class="relative flex items-center gap-3 py-1.5 px-2 rounded-lg">
                    <!-- Rank -->
                    <span class={`font-title text-xl leading-none w-6 shrink-0 text-right
                      ${i === 0 ? 'text-amber-400' : i === 1 ? 'text-neutral-400' : i === 2 ? 'text-orange-700' : 'text-neutral-700'}`}>
                      {i + 1}
                    </span>
                    <!-- Logo -->
                    <div class="w-8 h-8 shrink-0 flex items-center justify-center">
                      {(team.logo_dark || team.logo) ? (
                        <img src={team.logo_dark || team.logo} alt={team.name}
                          class="w-full h-full object-contain" />
                      ) : (
                        <span class="font-title text-xs text-neutral-600">
                          {team.name.substring(0,2).toUpperCase()}
                        </span>
                      )}
                    </div>
                    <!-- Name + bar -->
                    <div class="flex-1 min-w-0">
                      <div class="flex items-baseline justify-between gap-2">
                        <span class="font-title uppercase text-sm text-neutral-200 truncate leading-none">
                          {team.name}
                        </span>
                        <span class="font-mono text-xs text-neutral-500 shrink-0 tabular-nums">
                          {Math.round(team.rating)}
                        </span>
                      </div>
                      <!-- Mini rating bar -->
                      <div class="mt-1.5 h-px bg-neutral-900 rounded-full overflow-hidden">
                        <div class="h-full rounded-full transition-all duration-500"
                          style={`width: ${barWidth}%; background: ${color}; opacity: 0.6`}></div>
                      </div>
                    </div>
                  </div>
                </div>
              );
            })}
          </div>
        </a>

        <!-- META REPORT + COMING SOON stacked -->
        <div class="flex flex-col sm:flex-row lg:flex-col divide-y sm:divide-y-0 sm:divide-x lg:divide-x-0 lg:divide-y divide-neutral-900">

          <!-- Meta Report -->
          <a href="/stats"
            class="group bg-neutral-950 p-6 hover:bg-neutral-900/50 transition-colors flex-1">
            <div class="flex items-start justify-between mb-3">
              <div>
                <p class="font-mono text-[10px] uppercase tracking-[0.25em] text-violet-400 mb-0.5">Meta Report</p>
                <p class="font-mono text-[9px] uppercase tracking-widest text-neutral-700">Ban rates · Win rates</p>
              </div>
              <div class="flex items-center gap-1.5">
                <span class="font-mono text-[8px] uppercase tracking-widest text-violet-500 border border-violet-500/30 px-1.5 py-0.5 rounded">Beta</span>
                <svg class="w-3 h-3 text-neutral-700 group-hover:text-violet-400 transition-colors"
                  fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17L17 7M17 7H7M17 7v10"/>
                </svg>
              </div>
            </div>
            <p class="font-mono text-[11px] text-neutral-600 leading-relaxed">
              Hero ban patterns and win rates across all regions and stages.
            </p>
          </a>

          <!-- Coming soon placeholder — minimal, intentional -->
          <div class="bg-neutral-950 p-6 flex-1 flex flex-col justify-between opacity-40">
            <div>
              <p class="font-mono text-[10px] uppercase tracking-[0.25em] text-neutral-600 mb-0.5">Transfer Wire</p>
              <p class="font-mono text-[9px] uppercase tracking-widest text-neutral-800">Coming Season 3</p>
            </div>
            <div class="mt-4 flex items-center gap-1.5">
              <div class="h-px flex-1 bg-neutral-900"></div>
              <span class="font-mono text-[8px] uppercase tracking-widest text-neutral-800">Soon</span>
            </div>
          </div>

        </div>
      </div>

    </div>
  </div>

</BaseLayout>

<script>
  function initVideoEngine() {
    const container = document.getElementById("video-container");
    const p1 = document.getElementById("player-1") as HTMLVideoElement;
    const p2 = document.getElementById("player-2") as HTMLVideoElement;
    if (!container || !p1 || !p2) return;

    const clips = JSON.parse(container.dataset.clips || "[]");
    if (clips.length === 0) return;

    let activePlayer = p1;
    let standbyPlayer = p2;
    let currentClipIdx = clips.findIndex((c: string) => c === p1.src || p1.src.endsWith(c));
    if (currentClipIdx === -1) currentClipIdx = 0;

    setTimeout(() => prepareNextClip(), 3000);

    function prepareNextClip() {
      let nextIdx = currentClipIdx;
      while (nextIdx === currentClipIdx && clips.length > 1) {
        nextIdx = Math.floor(Math.random() * clips.length);
      }
      standbyPlayer.src = clips[nextIdx];
      standbyPlayer.load();
      currentClipIdx = nextIdx;
    }

    function switchPlayer() {
      standbyPlayer.play().then(() => {
        standbyPlayer.style.opacity = "0.5";
        activePlayer.style.opacity = "0";
        const temp = activePlayer;
        activePlayer = standbyPlayer;
        standbyPlayer = temp;
        setTimeout(() => {
          standbyPlayer.pause();
          prepareNextClip();
        }, 1000);
      }).catch((e) => console.log("Playback failed:", e));
    }

    p1.onended = () => { if (activePlayer === p1) switchPlayer(); };
    p2.onended = () => { if (activePlayer === p2) switchPlayer(); };
  }

  document.addEventListener("astro:page-load", initVideoEngine);
</script>
