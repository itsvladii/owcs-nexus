---
export const prerender = false;
import BaseLayout from "../layouts/BaseLayout.astro";
import { supabase } from "../lib/contentScripts/supabase";
import { Image } from "astro:assets";
import StatsFilters from "../components/statsComps/StatsFilters.svelte";
import { getHeroPortrait } from "../lib/stats/fetchHeroImg";
import MetaOOBE from "../components/statsComps/MetaOOBE.svelte";

//DATA FETCHING
const { data: rawMatches } = await supabase
    .from("processed_matches")
    .select("tournament, details, date, team_a, team_b")
    .not("details", "is", null)
    .order("date", { ascending: false });

const { data: rankingsRaw } = await supabase
    .from("rankings")
    .select("name, logo, logo_dark");

const teamLogoMap: Record<string, { logo: string; logoDark: string }> = {};
for (const t of rankingsRaw ?? []) {
    teamLogoMap[t.name] = { logo: t.logo ?? "", logoDark: t.logo_dark ?? "" };
}

//format hero ban data
interface TeamBanEntry {
    hero: string;
    count: number;
    pct: number;
}

interface TeamBanData {
    team: string;
    logo: string;
    logoDark: string;
    totalBans: number;
    bans: TeamBanEntry[];
}

function buildTeamBans(
    matches: typeof rawMatches,
): Record<string, TeamBanData> {
    const teamMap: Record<string, Record<string, number>> = {};
    for (const match of matches ?? []) {
        const maps = match.details?.maps ?? [];
        const teams = [match.team_a, match.team_b];
        for (const map of maps) {
            const bans: string[] = map.bans ?? [];
            bans.forEach((hero: string, idx: number) => {
                if (!hero || !teams[idx]) return;
                const team = teams[idx];
                if (!teamMap[team]) teamMap[team] = {};
                teamMap[team][hero] = (teamMap[team][hero] ?? 0) + 1;
            });
        }
    }
    const result: Record<string, TeamBanData> = {};
    for (const [team, heroCounts] of Object.entries(teamMap)) {
        const totalBans = Object.values(heroCounts).reduce((a, b) => a + b, 0);
        const bans: TeamBanEntry[] = Object.entries(heroCounts)
            .map(([hero, count]) => ({
                hero,
                count,
                pct: totalBans > 0 ? count / totalBans : 0,
            }))
            .sort((a, b) => b.count - a.count);
        const logos = teamLogoMap[team] ?? { logo: "", logoDark: "" };
        result[team] = {
            team,
            logo: logos.logo,
            logoDark: logos.logoDark,
            totalBans,
            bans,
        };
    }
    return result;
}

const teamBansAll = buildTeamBans(rawMatches);
const teamBansPerTournament: Record<string, Record<string, TeamBanData>> = {};
for (const t of [
    ...new Set(
        (rawMatches ?? []).map((m: any) => m.tournament).filter(Boolean),
    ),
]) {
    const tMatches = (rawMatches ?? []).filter((m: any) => m.tournament === t);
    teamBansPerTournament[t as string] = buildTeamBans(tMatches);
}
const teamList = Object.keys(teamBansAll).sort();

Astro.response.headers.set(
    "Cache-Control",
    "public, s-maxage=600, stale-while-revalidate=60",
);

const tournaments = [
    ...new Set((rawMatches ?? []).map((m) => m.tournament).filter(Boolean)),
].sort();

interface BanEntry {
    hero: string;
    count: number;
    maps: number;
    wins: number;
    banRate: number;
    winRate: number;
}

interface TournamentStats {
    tournament: string;
    totalMaps: number;
    totalBanSlots: number;
    bans: BanEntry[];
}

function aggregateBans(matches: typeof rawMatches): TournamentStats {
    const heroCounts: Record<string, { count: number; wins: number }> = {};
    let totalMaps = 0;
    let totalBanSlots = 0;

    for (const match of matches ?? []) {
        const maps = match.details?.maps ?? [];
        for (const map of maps) {
            totalMaps++;
            const bans: string[] = map.bans ?? [];
            bans.forEach((hero, idx) => {
                if (!hero) return;
                const normalized = hero.trim();
                if (!heroCounts[normalized])
                    heroCounts[normalized] = { count: 0, wins: 0 };
                heroCounts[normalized].count++;
                totalBanSlots++;
                const bannerWon = map.winner === String(idx + 1);
                if (bannerWon) heroCounts[normalized].wins++;
            });
        }
    }

    const bans: BanEntry[] = Object.entries(heroCounts)
        .map(([hero, { count, wins }]) => ({
            hero,
            count,
            maps: totalMaps,
            wins,
            banRate: totalBanSlots > 0 ? count / totalBanSlots : 0,
            winRate: count > 0 ? wins / count : 0,
        }))
        .sort((a, b) => b.count - a.count);

    return { tournament: "All", totalMaps, totalBanSlots, bans };
}

const perTournament: Record<string, TournamentStats> = {};
for (const t of tournaments) {
    const tMatches = (rawMatches ?? []).filter((m) => m.tournament === t);
    const stats = aggregateBans(tMatches);
    stats.tournament = t;
    perTournament[t] = stats;
}

const allStats = aggregateBans(rawMatches);
const topBanned = allStats.bans[0] ?? null;
const mostEffectiveBan =
    [...allStats.bans]
        .filter((b) => b.count >= 10)
        .sort((a, b) => b.winRate - a.winRate)[0] ?? null;
const totalMapsPlayed = allStats.totalMaps;

const lastMatch = rawMatches?.[0];
const lastUpdated = lastMatch?.date
    ? new Date(lastMatch.date).toLocaleDateString("en-US", {
          month: "long",
          day: "numeric",
          year: "numeric",
      })
    : null;

function shortenTournament(name: string): string {
    return name
        .replace(/Overwatch Champions Series/g, "OWCS")
        .replace(/ 20(\d\d)/g, " '$1")
        .replace(/Stage (\d)/g, "S$1")
        .replace(/Season (\d)/g, "S$1")
        .replace(/North America/g, "NA")
        .replace(/South Korea/g, "Korea")
        .trim();
}

const tournamentOptions = [
    { value: "All", label: "All Tournaments" },
    ...tournaments.map((t) => ({ value: t, label: shortenTournament(t) })),
];
---

<BaseLayout title="Meta Report | OWCS Nexus">
    <MetaOOBE client:only="svelte" />

    {/* ── HERO ── */}
    <div
        class="relative w-full overflow-hidden bg-[#0d0d0d] pt-32 pb-16 mb-12 min-h-[400px] flex items-end"
    >
        {/* Background image */}
        <div class="absolute inset-0 z-0">
            <Image
                src="https://live.staticflickr.com/65535/54698568446_b067ac6d1a_k.jpg"
                alt="Meta Report Background"
                width={1920}
                height={1080}
                format="webp"
                quality="mid"
                loading="eager"
                class="w-full h-full object-cover opacity-40 grayscale"
            />
            {/* Bottom fade — matches Charbon bg */}
            <div
                class="absolute inset-0 bg-gradient-to-t from-[#0d0d0d] via-[#0d0d0d]/60 to-transparent"
            >
            </div>
            {/* Side vignettes */}
            <div
                class="absolute inset-0 bg-gradient-to-r from-[#0d0d0d]/70 via-transparent to-[#0d0d0d]/70"
            >
            </div>
        </div>

        <div class="max-w-7xl mx-auto px-4 w-full relative z-10">
            {/* Eyebrow — same pattern as rankings page */}
            <div class="flex items-center gap-2.5 mb-4">
                <span
                    class="w-1.5 h-1.5 rounded-full bg-[#7B2FFF] animate-pulse shadow-[0_0_6px_#7B2FFF]"
                ></span>
                <span
                    class="font-mono text-[10px] uppercase tracking-[0.35em] text-white/40"
                >
                    OWCS Season 3 · Hero Ban Analysis
                </span>
            </div>

            {/* Title */}
            <h1
                class="text-6xl md:text-8xl lg:text-[8rem] font-title uppercase text-white leading-[0.85] mb-8 drop-shadow-2xl"
            >
                Meta <br />
                <span class="text-[#7B2FFF]">Report</span>
            </h1>

            {/* Meta strip */}
            <div
                class="flex flex-wrap items-center gap-4 font-mono text-[10px] uppercase tracking-widest text-white/30"
            >
                {/* Stats as outlined tags — matches rankings eyebrow style */}
                <span class="px-2.5 py-1 border border-white/10 text-white/50">
                    {totalMapsPlayed} Maps Analysed
                </span>
                {
                    lastUpdated && (
                        <span class="px-2.5 py-1 border border-white/10 text-white/50">
                            Updated {lastUpdated}
                        </span>
                    )
                }
            </div>
        </div>
    </div>

    {/* ── CALLOUT STRIP ── */}
    <div class="max-w-7xl mx-auto px-4 mb-12">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-px bg-white/5">
            {/* Most Banned — spans 2 cols, Bleu Électrique accent */}
            {
                topBanned && (
                    <div class="col-span-2 bg-[#0d0d0d] p-6 relative overflow-hidden">
                        {/* Hero portrait bleed — same technique as stat cards */}
                        <img
                            src={getHeroPortrait(topBanned.hero)}
                            alt={topBanned.hero}
                            class="absolute right-0 top-0 h-full w-56 object-cover object-top pointer-events-none"
                            style="opacity: 0.15; mask-image: linear-gradient(to left, black 0%, transparent 100%); -webkit-mask-image: linear-gradient(to left, black 0%, transparent 100%);"
                        />
                        {/* Blue left accent bar */}
                        <div class="absolute left-0 top-0 bottom-0 w-[3px] bg-[#7B2FFF] shadow-[2px_0_12px_rgba(123,47,255,0.4)]" />
                        <div
                            class="absolute inset-0 pointer-events-none"
                            style="background: radial-gradient(ellipse at 0% 50%, rgba(123,47,255,0.05) 0%, transparent 55%)"
                        ></div>

                        <div class="relative z-10 pl-3">
                            <p class="font-mono text-[9px] uppercase tracking-[0.35em] text-[#7B2FFF] mb-2">
                                Most Banned Hero
                            </p>
                            <div class="flex items-end gap-4">
                                <p class="font-title text-4xl sm:text-5xl text-white uppercase leading-none">
                                    {topBanned.hero}
                                </p>
                                <div class="mb-0.5">
                                    <p class="font-mono font-black text-2xl text-[#7B2FFF] tabular-nums leading-none">
                                        {topBanned.count}×
                                    </p>
                                    <p class="font-mono text-[9px] text-white/25 uppercase tracking-widest mt-1">
                                        {(topBanned.banRate * 100).toFixed(1)}%
                                        of ban slots
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>
                )
            }

            {/* Total Bans */}
            <div class="bg-[#0d0d0d] p-6 relative">
                <div class="absolute left-0 top-0 bottom-0 w-[3px] bg-white/8">
                </div>
                <div class="pl-3">
                    <p
                        class="font-mono text-[9px] uppercase tracking-[0.35em] text-white/25 mb-2"
                    >
                        Total Bans
                    </p>
                    <p
                        class="font-mono font-black text-4xl text-white tabular-nums leading-none"
                    >
                        {allStats.totalBanSlots}
                    </p>
                    <p
                        class="font-mono text-[9px] text-white/20 uppercase tracking-widest mt-2"
                    >
                        across all maps
                    </p>
                </div>
            </div>

            {/* Most Effective Ban */}
            {
                mostEffectiveBan && (
                    <div class="bg-[#0d0d0d] p-6 relative overflow-hidden">
                        <img
                            src={getHeroPortrait(mostEffectiveBan.hero)}
                            alt={mostEffectiveBan.hero}
                            class="absolute right-0 top-0 h-full w-24 object-cover object-top pointer-events-none"
                            style="opacity: 0.10; mask-image: linear-gradient(to left, black 0%, transparent 100%); -webkit-mask-image: linear-gradient(to left, black 0%, transparent 100%);"
                        />
                        {/* Rose Lumineux accent — effective = standout stat */}
                        <div class="absolute left-0 top-0 bottom-0 w-[3px] bg-[#FF7FDE] shadow-[2px_0_10px_rgba(255,127,222,0.25)]" />
                        <div
                            class="absolute inset-0 pointer-events-none"
                            style="background: radial-gradient(ellipse at 0% 50%, rgba(255,127,222,0.04) 0%, transparent 55%)"
                        ></div>

                        <div class="relative z-10 pl-3">
                            <p class="font-mono text-[9px] uppercase tracking-[0.35em] text-[#FF7FDE] mb-2">
                                Most Effective Ban
                            </p>
                            <p class="font-mono font-black text-4xl text-white tabular-nums leading-none">
                                {(mostEffectiveBan.winRate * 100).toFixed(0)}%
                            </p>
                            <p class="font-mono text-[9px] text-white/25 uppercase tracking-widest mt-1">
                                win rate
                            </p>
                            <p class="font-title uppercase text-[#FF7FDE] text-sm mt-2 leading-none">
                                {mostEffectiveBan.hero}
                            </p>
                            <p class="font-mono text-[9px] text-white/20 mt-0.5">
                                {mostEffectiveBan.count} bans
                            </p>
                        </div>
                    </div>
                )
            }
        </div>
    </div>

    {/* ── MAIN CONTENT ── */}
    <div class="max-w-7xl mx-auto px-4 pb-24">
        <StatsFilters
            allStats={allStats}
            perTournament={perTournament}
            tournamentOptions={tournamentOptions}
            teamBansAll={teamBansAll}
            teamBansPerTournament={teamBansPerTournament}
            teamList={teamList}
            client:load
        />
    </div>
</BaseLayout>
