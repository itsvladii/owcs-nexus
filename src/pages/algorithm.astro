---
// src/pages/algorithm.astro
import { getEntry } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const doc = await getEntry("docs", "algorithm");

if (!doc) {
    throw new Error("Could not find src/content/docs/algorithm.md");
}

const { Content, headings } = await doc.render();

// Build a nested TOC structure (h2 = section, h3 = subsection)
const tocSections = headings.reduce(
    (acc, h) => {
        if (h.depth === 2) {
            acc.push({ ...h, children: [] });
        } else if (h.depth === 3 && acc.length > 0) {
            acc[acc.length - 1].children.push(h);
        }
        return acc;
    },
    [] as Array<{
        slug: string;
        text: string;
        children: Array<{ slug: string; text: string }>;
    }>,
);
---

<BaseLayout title={doc.data.title}>
    <!-- ⚡ Non-blocking KaTeX -->
    <link
        rel="preload"
        href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css"
        integrity="sha384-n8MVd4RsNIU0tAv4ct0nTaAbDJwPJzDEaqSD1odI+WdtXRGWt2kTvGFasHpSy3SV"
        crossorigin="anonymous"
        as="style"
        onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript>
        <link
            rel="stylesheet"
            href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css"
            integrity="sha384-n8MVd4RsNIU0tAv4ct0nTaAbDJwPJzDEaqSD1odI+WdtXRGWt2kTvGFasHpSy3SV"
            crossorigin="anonymous"
        />
    </noscript>

    <!-- ── Page shell: sidebar + content ───────────────────────────────────── -->
    <div class="docs-layout">
        <!-- ── Sidebar ──────────────────────────────────────────────────────── -->
        <aside class="docs-sidebar" id="docs-sidebar">
            <div class="sidebar-inner">
                <div class="sidebar-header">
                    <p class="sidebar-label">Documentation</p>
                    <h2 class="sidebar-title">ELO System</h2>
                </div>

                <nav aria-label="Table of contents">
                    <ol class="toc-list">
                        {
                            tocSections.map((section, i) => (
                                <li class="toc-section">
                                    <a
                                        href={`#${section.slug}`}
                                        class="toc-link toc-link-h2"
                                        data-slug={section.slug}
                                    >
                                        <span class="toc-text">
                                            {section.text}
                                        </span>
                                    </a>

                                    {section.children.length > 0 && (
                                        <ol class="toc-sublist">
                                            {section.children.map((child) => (
                                                <li>
                                                    <a
                                                        href={`#${child.slug}`}
                                                        class="toc-link toc-link-h3"
                                                        data-slug={child.slug}
                                                    >
                                                        {child.text}
                                                    </a>
                                                </li>
                                            ))}
                                        </ol>
                                    )}
                                </li>
                            ))
                        }
                    </ol>
                </nav>
            </div>
        </aside>

        <!-- ── Mobile TOC trigger (sticky pill) ─────────────────────────────── -->
        <div class="mobile-nav-trigger">
            <button
                class="toc-mobile-open"
                id="toc-mobile-open"
                aria-label="Open navigation"
            >
                <svg
                    width="14"
                    height="14"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2.5"
                        d="M4 6h16M4 10h10M4 14h16M4 18h10"></path>
                </svg>
                Menu
            </button>
        </div>

        <!-- ── Main content ──────────────────────────────────────────────────── -->
        <main class="docs-main">
            <!-- Breadcrumbs -->
            <nav class="docs-breadcrumbs" aria-label="Breadcrumb">
                <ol>
                    <li><a href="/">Home</a></li>
                    <li>
                        <svg
                            width="10"
                            height="10"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="3"
                            ><path d="M9 18l6-6-6-6"></path></svg>
                    </li>
                    <li><span aria-current="page">Algorithm</span></li>
                </ol>
            </nav>

            <!-- Header -->
            <header class="doc-header">
                <h1 class="doc-title">{doc.data.title}</h1>
                <p class="doc-desc">{doc.data.description}</p>

                <div class="doc-meta-grid">
                    <div class="meta-item">
                        <span class="meta-label">Version</span>
                        <span class="meta-value">v{doc.data.version}</span>
                    </div>
                    <div class="meta-item">
                        <span class="meta-label">Last Updated</span>
                        <span class="meta-value"
                            >{
                                doc.data.lastUpdated.toLocaleDateString(
                                    "en-US",
                                    {
                                        month: "long",
                                        day: "numeric",
                                        year: "numeric",
                                    },
                                )
                            }</span
                        >
                    </div>
                    <div class="meta-item">
                        <span class="meta-label">Status</span>
                        <span class="meta-value status-active">
                            <span class="status-dot"></span>
                            Stable
                        </span>
                    </div>
                </div>
            </header>

            <!-- Article -->
            <article
                class="doc-article prose prose-invert prose-sm sm:prose-base lg:prose-lg max-w-none
        prose-headings:text-white prose-headings:font-bold prose-headings:tracking-tight
        prose-h1:text-4xl prose-h1:mb-8
        prose-h2:text-2xl prose-h2:mt-12 prose-h2:mb-6 prose-h2:pb-3 prose-h2:border-b prose-h2:border-white/5
        prose-h3:text-lg prose-h3:mt-8 prose-h3:mb-4
        prose-p:text-neutral-400 prose-p:leading-relaxed
        prose-strong:text-white
        prose-code:text-blue-400 prose-code:bg-blue-400/5 prose-code:border prose-code:border-blue-400/20 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded prose-code:font-mono prose-code:before:content-none prose-code:after:content-none
        prose-pre:bg-[#0d1117] prose-pre:border prose-pre:border-white/5
        prose-ul:text-neutral-400 prose-li:marker:text-neutral-600
        prose-table:w-full prose-table:my-8
        prose-th:text-white prose-th:font-semibold prose-th:text-sm prose-th:p-3 prose-th:bg-white/5
        prose-td:p-3 prose-td:border-white/5 prose-td:text-sm
        prose-blockquote:border-l-2 prose-blockquote:border-blue-500 prose-blockquote:bg-blue-500/5 prose-blockquote:py-1 prose-blockquote:px-6 prose-blockquote:not-italic prose-blockquote:text-neutral-300"
            >
                <Content />
            </article>

            <!-- Footer -->
            <footer class="doc-footer">
                <div class="doc-footer-nav">
                    <p class="text-neutral-500">
                        Nexus ELO Documentation · Open Source Algorithm
                    </p>
                    <a href="#top" class="doc-back-top">
                        <svg
                            width="12"
                            height="12"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2.5"
                                d="M5 15l7-7 7 7"></path>
                        </svg>
                        Back to top
                    </a>
                </div>
            </footer>
        </main>
    </div>

    <!-- Mobile backdrop -->
    <div class="toc-backdrop" id="toc-backdrop"></div>
</BaseLayout>

<style is:global>
    /* ── Layout ──────────────────────────────────────────────────────────────── */
    .docs-layout {
        display: flex;
        max-width: 1440px;
        margin: 0 auto;
        padding: 0 2rem;
        padding-top: 6rem;
        min-height: 100vh;
    }

    /* ── Sidebar ─────────────────────────────────────────────────────────────── */
    .docs-sidebar {
        position: sticky;
        top: 6rem;
        width: 280px;
        flex-shrink: 0;
        height: calc(100vh - 6rem);
        overflow-y: auto;
        padding: 2rem 0;
        padding-right: 2rem;
        border-right: 1px solid rgba(255, 255, 255, 0.06);
    }

    .sidebar-header {
        margin-bottom: 2rem;
    }

    .sidebar-label {
        font-size: 0.7rem;
        font-weight: 600;
        color: #3b82f6;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        margin-bottom: 0.25rem;
    }

    .sidebar-title {
        font-size: 1.25rem;
        font-weight: 800;
        color: #fff;
        letter-spacing: -0.02em;
    }

    /* ── TOC list ────────────────────────────────────────────────────────────── */
    .toc-list {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .toc-link {
        display: block;
        padding: 0.4rem 0.75rem;
        font-size: 0.875rem;
        color: rgba(255, 255, 255, 0.4);
        text-decoration: none;
        border-radius: 0.5rem;
        transition: all 0.2s ease;
        border: 1px solid transparent;
    }

    .toc-link:hover {
        color: #fff;
        background: rgba(255, 255, 255, 0.03);
    }

    .toc-link.active {
        color: #fff;
        background: rgba(59, 130, 246, 0.1);
        border-color: rgba(59, 130, 246, 0.2);
        font-weight: 600;
    }

    .toc-sublist {
        list-style: none;
        margin: 0.25rem 0 0.75rem 1rem;
        padding: 0;
        border-left: 1px solid rgba(255, 255, 255, 0.06);
    }

    .toc-link-h3 {
        padding-left: 1rem;
        font-size: 0.8rem;
    }

    /* ── Main content ────────────────────────────────────────────────────────── */
    .docs-main {
        flex: 1;
        min-width: 0;
        padding: 2rem 0 6rem 4rem;
        max-width: 900px;
    }

    /* ── Breadcrumbs ─────────────────────────────────────────────────────────── */
    .docs-breadcrumbs ol {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        list-style: none;
        padding: 0;
        margin: 0 0 2rem 0;
    }

    .docs-breadcrumbs li {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        font-size: 0.8rem;
        color: rgba(255, 255, 255, 0.3);
    }

    .docs-breadcrumbs a {
        color: inherit;
        text-decoration: none;
        transition: color 0.2s;
    }

    .docs-breadcrumbs a:hover {
        color: #fff;
    }

    /* ── Header ──────────────────────────────────────────────────────────────── */
    .doc-header {
        margin-bottom: 4rem;
    }

    .doc-title {
        font-size: 3.5rem;
        font-weight: 800;
        color: #fff;
        letter-spacing: -0.04em;
        line-height: 1.1;
        margin-bottom: 1.5rem;
    }

    .doc-desc {
        font-size: 1.25rem;
        color: rgba(255, 255, 255, 0.5);
        line-height: 1.6;
        margin-bottom: 2rem;
        max-width: 700px;
    }

    .doc-meta-grid {
        display: flex;
        gap: 3rem;
        padding-top: 2rem;
        border-top: 1px solid rgba(255, 255, 255, 0.06);
    }

    .meta-item {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }

    .meta-label {
        font-size: 0.65rem;
        font-weight: 700;
        color: rgba(255, 255, 255, 0.2);
        text-transform: uppercase;
        letter-spacing: 0.1em;
    }

    .meta-value {
        font-size: 0.9rem;
        font-weight: 500;
        color: rgba(255, 255, 255, 0.8);
    }

    .status-active {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        color: #10b981;
    }

    .status-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: currentColor;
        box-shadow: 0 0 8px currentColor;
    }

    /* ── Blockquotes ─────────────────────────────────────────────────────────── */
    article blockquote {
        border-radius: 0.75rem;
        margin: 2.5rem 0 !important;
    }

    article blockquote.warning {
        border-left: 2px solid #f59e0b;
        background: rgba(245, 158, 11, 0.03);
        border-radius: 0 0.75rem 0.75rem 0;
    }

    article blockquote.warning strong:first-of-type {
        color: #f59e0b !important;
    }

    /* ── Mobile ──────────────────────────────────────────────────────────────── */
    @media (max-width: 1023px) {
        .docs-layout {
            display: block;
            padding-top: 5rem;
        }

        .docs-sidebar {
            position: fixed;
            top: 0;
            left: 0;
            height: 100vh;
            width: 300px;
            z-index: 50;
            background: #050505;
            padding: 2rem;
            transform: translateX(-100%);
            transition: transform 0.3s ease;
            border-right: 1px solid rgba(255, 255, 255, 0.1);
        }

        .docs-sidebar.open {
            transform: translateX(0);
        }

        .mobile-nav-trigger {
            position: sticky;
            top: 5rem;
            z-index: 30;
            margin-bottom: 2rem;
        }

        .toc-mobile-open {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.5rem 1rem;
            background: rgba(10, 10, 10, 0.8);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 0.5rem;
            color: #fff;
            font-size: 0.8rem;
            font-weight: 600;
        }

        .docs-main {
            padding: 0;
        }

        .doc-title {
            font-size: 2.5rem;
        }

        .doc-meta-grid {
            flex-direction: column;
            gap: 1.5rem;
        }
    }
</style>

<script>
    // ── Mobile drawer ────────────────────────────────────────────────────────────
    const sidebar = document.getElementById("docs-sidebar")!;
    const backdrop = document.getElementById("toc-backdrop")!;
    const openBtn = document.getElementById("toc-mobile-open")!;
    const closeBtn = document.getElementById("toc-mobile-close")!;

    function openDrawer() {
        sidebar.classList.add("open");
        backdrop.classList.add("open");
        document.body.style.overflow = "hidden";
    }
    function closeDrawer() {
        sidebar.classList.remove("open");
        backdrop.classList.remove("open");
        document.body.style.overflow = "";
    }

    openBtn?.addEventListener("click", openDrawer);
    closeBtn?.addEventListener("click", closeDrawer);
    backdrop?.addEventListener("click", closeDrawer);

    // Close on link tap (mobile)
    sidebar?.querySelectorAll("a").forEach((link) => {
        link.addEventListener("click", () => {
            if (window.innerWidth < 1024) closeDrawer();
        });
    });

    // ── Active link highlight (IntersectionObserver) ───────────────────────────
    const headingEls = document.querySelectorAll(
        ".doc-article h2, .doc-article h3",
    );
    const tocLinks = document.querySelectorAll<HTMLAnchorElement>(".toc-link");

    if (headingEls.length && tocLinks.length) {
        const observer = new IntersectionObserver(
            (entries) => {
                for (const entry of entries) {
                    if (entry.isIntersecting) {
                        const id = entry.target.getAttribute("id");
                        tocLinks.forEach((link) => {
                            link.classList.toggle(
                                "active",
                                link.dataset.slug === id,
                            );
                        });
                    }
                }
            },
            { rootMargin: "-8% 0px -82% 0px" },
        );
        headingEls.forEach((el) => observer.observe(el));
    }
</script>
