---
// src/pages/algorithm.astro
import { getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const doc = await getEntry('docs', 'algorithm');

if (!doc) {
  throw new Error('Could not find src/content/docs/algorithm.md');
}

const { Content, headings } = await doc.render();

// Build a nested TOC structure (h2 = section, h3 = subsection)
const tocSections = headings.reduce((acc, h) => {
  if (h.depth === 2) {
    acc.push({ ...h, children: [] });
  } else if (h.depth === 3 && acc.length > 0) {
    acc[acc.length - 1].children.push(h);
  }
  return acc;
}, [] as Array<{ slug: string; text: string; children: Array<{ slug: string; text: string }> }>);
---

<BaseLayout title={doc.data.title}>

  <!-- ⚡ Non-blocking KaTeX -->
  <link
    rel="preload"
    href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css"
    integrity="sha384-n8MVd4RsNIU0tAv4ct0nTaAbDJwPJzDEaqSD1odI+WdtXRGWt2kTvGFasHpSy3SV"
    crossorigin="anonymous"
    as="style"
    onload="this.onload=null;this.rel='stylesheet'"
  />
  <noscript>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css"
      integrity="sha384-n8MVd4RsNIU0tAv4ct0nTaAbDJwPJzDEaqSD1odI+WdtXRGWt2kTvGFasHpSy3SV" crossorigin="anonymous" />
  </noscript>

  <!-- ── Page shell: sidebar + content ───────────────────────────────────── -->
  <div class="docs-layout">

    <!-- ── Sidebar ──────────────────────────────────────────────────────── -->
    <aside class="docs-sidebar" id="docs-sidebar">

      <!-- Mobile close button -->
      <button class="toc-mobile-close" id="toc-mobile-close" aria-label="Close navigation">
        <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>

      <div class="sidebar-inner">
        <p class="sidebar-label">On this page</p>

        <nav aria-label="Table of contents">
          <ol class="toc-list">
            {tocSections.map((section, i) => (
              <li class="toc-section">
                <a
                  href={`#${section.slug}`}
                  class="toc-link toc-link-h2"
                  data-slug={section.slug}
                >
                  <span class="toc-index">{String(i + 1).padStart(2, '0')}</span>
                  <span class="toc-text">{section.text}</span>
                </a>

                {section.children.length > 0 && (
                  <ol class="toc-sublist">
                    {section.children.map(child => (
                      <li>
                        <a
                          href={`#${child.slug}`}
                          class="toc-link toc-link-h3"
                          data-slug={child.slug}
                        >
                          {child.text}
                        </a>
                      </li>
                    ))}
                  </ol>
                )}
              </li>
            ))}
          </ol>
        </nav>
      </div>
    </aside>

    <!-- ── Mobile TOC trigger (sticky pill) ─────────────────────────────── -->
    <button class="toc-mobile-open" id="toc-mobile-open" aria-label="Open navigation">
      <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 6h16M4 10h10M4 14h16M4 18h10"/>
      </svg>
      On this page
    </button>

    <!-- ── Main content ──────────────────────────────────────────────────── -->
    <main class="docs-main">

      <!-- Header -->
      <div class="doc-header">
        <div class="doc-badge">
          <span class="badge-dot"></span>
          System Documentation v{doc.data.version}
        </div>
        <h1 class="doc-title">{doc.data.title}</h1>
        <p class="doc-desc">{doc.data.description}</p>
        <p class="doc-meta">Last updated: {doc.data.lastUpdated.toLocaleDateString()}</p>
      </div>

      <!-- Article -->
      <article class="doc-article prose prose-invert prose-sm sm:prose-base md:prose-lg max-w-none
        prose-headings:font-black prose-headings:uppercase prose-headings:text-white
        prose-p:text-neutral-400 prose-p:font-light prose-p:leading-relaxed
        prose-strong:text-white prose-strong:font-bold
        prose-code:text-emerald-400 prose-code:bg-neutral-900/50 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded prose-code:font-mono prose-code:before:content-none prose-code:after:content-none
        prose-ul:text-neutral-400 prose-li:marker:text-neutral-600
        prose-table:border-collapse prose-table:w-full prose-table:my-8
        prose-thead:bg-neutral-900/50
        prose-th:text-white prose-th:font-bold prose-th:uppercase prose-th:text-xs prose-th:tracking-wider prose-th:p-4 prose-th:border prose-th:border-white/10
        prose-td:p-4 prose-td:border prose-td:border-white/5 prose-td:text-sm prose-td:font-mono
        prose-blockquote:border-l-4 prose-blockquote:border-emerald-500 prose-blockquote:bg-emerald-500/5 prose-blockquote:py-2 prose-blockquote:px-6 prose-blockquote:not-italic prose-blockquote:text-emerald-100">
        <Content />
      </article>

      <!-- Footer -->
      <div class="doc-footer">
        <span class="doc-footer-meta">Algorithm v{doc.data.version} · {doc.data.lastUpdated.toLocaleDateString()}</span>
        <a href="#top" class="doc-back-top">
          <svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 15l7-7 7 7"/>
          </svg>
          Back to top
        </a>
      </div>

    </main>
  </div>

  <!-- Mobile backdrop -->
  <div class="toc-backdrop" id="toc-backdrop"></div>

</BaseLayout>

<style is:global>

  /* ── Layout ──────────────────────────────────────────────────────────────── */

  .docs-layout {
    display: flex;
    align-items: flex-start;
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 1.5rem;
    padding-top: 5rem;
    gap: 0;
  }

  /* ── Sidebar ─────────────────────────────────────────────────────────────── */

  .docs-sidebar {
    position: sticky;
    top: 5rem;
    width: 240px;
    flex-shrink: 0;
    height: calc(100vh - 6rem);
    overflow-y: auto;
    overflow-x: hidden;
    padding: 2rem 0;
    scrollbar-width: none;
    border-right: 1px solid rgba(255,255,255,0.06);
    margin-right: 3rem;
  }
  .docs-sidebar::-webkit-scrollbar { display: none; }

  .sidebar-inner { padding-right: 1.5rem; }

  .sidebar-label {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.25);
    margin-bottom: 1rem;
    padding-left: 0.25rem;
  }

  /* ── TOC list ────────────────────────────────────────────────────────────── */

  .toc-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .toc-section {
    display: flex;
    flex-direction: column;
  }

  .toc-link {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    padding: 0.3rem 0.5rem;
    border-radius: 0.375rem;
    text-decoration: none;
    transition: color 0.15s, background 0.15s;
    position: relative;
  }

  .toc-link-h2 {
    font-size: 0.75rem;
    font-weight: 500;
    color: rgba(255,255,255,0.4);
  }
  .toc-link-h2:hover {
    color: rgba(255,255,255,0.85);
    background: rgba(255,255,255,0.04);
  }
  .toc-link-h2.active {
    color: #fff;
    background: rgba(255,255,255,0.05);
  }
  .toc-link-h2.active::before {
    content: '';
    position: absolute;
    left: -1px;
    top: 20%;
    height: 60%;
    width: 2px;
    background: #3b82f6;
    border-radius: 1px;
  }

  .toc-index {
    font-size: 0.6rem;
    font-family: ui-monospace, monospace;
    color: rgba(255,255,255,0.2);
    min-width: 1.25rem;
    transition: color 0.15s;
    flex-shrink: 0;
  }
  .toc-link-h2.active .toc-index,
  .toc-link-h2:hover .toc-index { color: #60a5fa; }

  .toc-text { line-height: 1.4; }

  .toc-sublist {
    list-style: none;
    margin: 0.125rem 0 0.25rem 0;
    padding: 0;
    border-left: 1px solid rgba(255,255,255,0.06);
    margin-left: 1.25rem;
    padding-left: 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.0625rem;
  }

  .toc-link-h3 {
    font-size: 0.7rem;
    color: rgba(255,255,255,0.28);
    padding: 0.2rem 0.375rem;
    border-radius: 0.25rem;
    transition: color 0.15s, background 0.15s;
    line-height: 1.5;
  }
  .toc-link-h3:hover {
    color: rgba(255,255,255,0.65);
    background: rgba(255,255,255,0.04);
  }
  .toc-link-h3.active { color: rgba(255,255,255,0.85); }

  /* ── Main content ────────────────────────────────────────────────────────── */

  .docs-main {
    flex: 1;
    min-width: 0;
    padding: 2rem 0 4rem;
    max-width: 780px;
  }

  /* ── Header ──────────────────────────────────────────────────────────────── */

  .doc-header {
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid rgba(255,255,255,0.07);
  }

  .doc-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    border: 1px solid rgba(59,130,246,0.3);
    background: rgba(59,130,246,0.1);
    color: #60a5fa;
    font-size: 0.625rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 1.5rem;
  }

  .badge-dot {
    width: 0.375rem;
    height: 0.375rem;
    border-radius: 9999px;
    background: #3b82f6;
    animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .doc-title {
    font-size: clamp(2.25rem, 5vw, 3.75rem);
    font-weight: 900;
    color: #fff;
    text-transform: uppercase;
    letter-spacing: -0.04em;
    line-height: 1;
    margin: 0 0 1rem;
  }

  .doc-desc {
    font-size: 1.125rem;
    color: rgba(255,255,255,0.4);
    font-weight: 300;
    margin: 0 0 1.25rem;
  }

  .doc-meta {
    font-size: 0.7rem;
    font-family: ui-monospace, monospace;
    color: rgba(255,255,255,0.25);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0;
  }

  /* ── Article ─────────────────────────────────────────────────────────────── */

  .doc-article {
    content-visibility: auto;
    contain-intrinsic-size: 0 8000px;
  }

  .doc-article table {
    display: block;
    width: 100%;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .katex-display {
    margin: 1.5rem 0;
    overflow-x: auto;
    overflow-y: hidden;
    padding-bottom: 0.5rem;
    scrollbar-width: thin;
  }
  .katex-display .katex { color: #fbbf24; }

  /* ── Blockquotes ─────────────────────────────────────────────────────────── */

  article blockquote p::before,
  article blockquote p::after { content: none !important; }
  article blockquote { font-style: normal !important; }

  article blockquote.warning {
    border-left: 4px solid #f59e0b;
    background: rgba(245,158,11,0.05);
    color: #fef3c7;
    padding: 1.5rem;
    margin: 2rem 0;
    border-radius: 0 0.5rem 0.5rem 0;
  }
  article blockquote.warning strong:first-of-type {
    color: #f59e0b !important;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    display: inline-block;
    margin-right: 0.5rem;
  }
  article blockquote.info {
    border-left: 4px solid #10b981;
    background: rgba(16,185,129,0.05);
    color: #ecfdf5;
    padding: 1.5rem;
    margin: 2rem 0;
    border-radius: 0 0.5rem 0.5rem 0;
  }
  article blockquote.info strong:first-of-type {
    color: #10b981 !important;
    display: block;
    margin-bottom: 0.5rem;
    font-size: 1.1rem;
  }

  /* ── Footer ──────────────────────────────────────────────────────────────── */

  .doc-footer {
    margin-top: 4rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(255,255,255,0.07);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .doc-footer-meta {
    font-size: 0.65rem;
    font-family: ui-monospace, monospace;
    color: rgba(255,255,255,0.2);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .doc-back-top {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(255,255,255,0.3);
    text-decoration: none;
    transition: color 0.15s;
  }
  .doc-back-top:hover { color: #fff; }

  /* ── Mobile drawer ───────────────────────────────────────────────────────── */

  .toc-mobile-open { display: none; }
  .toc-mobile-close { display: none; }
  .toc-backdrop { display: none; }

  @media (max-width: 1023px) {

    .docs-layout {
      display: block;
      padding-top: 4rem;
    }

    /* Sidebar becomes slide-in drawer */
    .docs-sidebar {
      position: fixed;
      top: 0;
      left: 0;
      height: 100dvh;
      width: 280px;
      z-index: 50;
      background: #0a0a0a;
      border-right: 1px solid rgba(255,255,255,0.08);
      padding: 4rem 1.5rem 2rem;
      transform: translateX(-100%);
      transition: transform 0.25s ease;
      margin-right: 0;
    }
    .docs-sidebar.open { transform: translateX(0); }

    .sidebar-inner { padding-right: 0; }

    .toc-backdrop {
      display: block;
      position: fixed;
      inset: 0;
      z-index: 40;
      background: rgba(0,0,0,0.6);
      backdrop-filter: blur(2px);
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.25s ease;
    }
    .toc-backdrop.open {
      opacity: 1;
      pointer-events: auto;
    }

    /* Floating pill trigger */
    .toc-mobile-open {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      position: sticky;
      top: 4.5rem;
      z-index: 30;
      margin-bottom: 1.5rem;
      padding: 0.45rem 0.9rem;
      border-radius: 9999px;
      border: 1px solid rgba(255,255,255,0.1);
      background: rgba(10,10,10,0.9);
      backdrop-filter: blur(8px);
      font-size: 0.7rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: rgba(255,255,255,0.5);
      cursor: pointer;
      transition: color 0.15s, border-color 0.15s;
    }
    .toc-mobile-open:hover {
      color: #fff;
      border-color: rgba(255,255,255,0.25);
    }

    .toc-mobile-close {
      display: flex;
      align-items: center;
      justify-content: center;
      position: absolute;
      top: 1rem;
      right: 1rem;
      width: 2rem;
      height: 2rem;
      border-radius: 0.375rem;
      border: 1px solid rgba(255,255,255,0.1);
      background: transparent;
      color: rgba(255,255,255,0.4);
      cursor: pointer;
      transition: color 0.15s;
    }
    .toc-mobile-close:hover { color: #fff; }

    .docs-main {
      max-width: 100%;
      padding: 0 0 4rem;
    }
  }

  @media (max-width: 640px) {
    .katex { font-size: 0.95em; }
  }

  /* ── Smooth scroll ────────────────────────────────────────────────────────── */
  html {
    scroll-behavior: smooth;
    scroll-padding-top: 5rem;
  }
</style>

<script>
  // ── Mobile drawer ────────────────────────────────────────────────────────────
  const sidebar  = document.getElementById('docs-sidebar')!;
  const backdrop = document.getElementById('toc-backdrop')!;
  const openBtn  = document.getElementById('toc-mobile-open')!;
  const closeBtn = document.getElementById('toc-mobile-close')!;

  function openDrawer() {
    sidebar.classList.add('open');
    backdrop.classList.add('open');
    document.body.style.overflow = 'hidden';
  }
  function closeDrawer() {
    sidebar.classList.remove('open');
    backdrop.classList.remove('open');
    document.body.style.overflow = '';
  }

  openBtn?.addEventListener('click', openDrawer);
  closeBtn?.addEventListener('click', closeDrawer);
  backdrop?.addEventListener('click', closeDrawer);

  // Close on link tap (mobile)
  sidebar?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      if (window.innerWidth < 1024) closeDrawer();
    });
  });

  // ── Active link highlight (IntersectionObserver) ───────────────────────────
  const headingEls = document.querySelectorAll('.doc-article h2, .doc-article h3');
  const tocLinks   = document.querySelectorAll<HTMLAnchorElement>('.toc-link');

  if (headingEls.length && tocLinks.length) {
    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            const id = entry.target.getAttribute('id');
            tocLinks.forEach(link => {
              link.classList.toggle('active', link.dataset.slug === id);
            });
          }
        }
      },
      { rootMargin: '-8% 0px -82% 0px' }
    );
    headingEls.forEach(el => observer.observe(el));
  }
</script>