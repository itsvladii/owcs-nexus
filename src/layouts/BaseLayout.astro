---
// src/layouts/BaseLayout.astro
import '../styles/global.css'; // <-- THIS IS THE CRITICAL LINE
import { ClientRouter } from "astro:transitions";
import SpeedInsights from "@vercel/speed-insights/astro";
import Image from 'astro/components/Image.astro';
export interface Props {
  title: string;
}
const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title} | OWCS Nexus</title>
    <meta name="generator" content={Astro.generator} />
    <ClientRouter/>
  <link
  rel="preload"
  href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css"
  as="style"
  onload="this.onload=null;this.rel='stylesheet'"
/>
  <link rel="manifest" href="/manifest.webmanifest" />
  <meta name="theme-color" content="#dc2626" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  </head>
  
  
  <body class="bg-neutral-950 text-gray-200">
    <SpeedInsights />
    {/* Header for the "OWCS Wiki" title */}
    <header class="absolute top-0 left-0 w-full py-8 z-50 bg-gradient-to-b from-black/80 to-transparent">
      <div class="max-w-7xl mx-auto px-4 flex items-center justify-between"> {/* Changed to justify-between */}
    
    {/* Left: Empty div or Links (to balance the center logo if needed) */}
    <div class="w-32 hidden md:block">
    </div>

    {/* Center: Logo */}
    <a href="/" class="block hover:opacity-80 transition-opacity">
      <Image src="/nexus_logo.png" width={85} 
        height={48} alt="OWCS Nexus" class="h-12 w-auto" />
    </a>

    {/* Right: Search Bar */}
    <div class="flex items-center justify-end w-auto min-w-[140px]">
</div>

  </div>
    </header>

    <main>
      <slot />
    </main>
    
    <footer class="mt-24 py-12 border-t border-white/5 bg-neutral-950/50 backdrop-blur-sm">
  <div class="max-w-7xl mx-auto px-6 text-center">
    
    <div class="max-w-xl mx-auto space-y-6">
      <p class="text-neutral-500 text-[10px] md:text-[11px] leading-loose font-mono uppercase tracking-tight">
        OWCS Nexus is an <span class="text-neutral-400">unofficial fan project</span>. 
        This site is not affiliated with, endorsed by, or sponsored by Blizzard Entertainment or the Overwatch Champions Series.
      </p>

      <p class="text-neutral-600 text-[9px] md:text-[10px] leading-relaxed font-mono uppercase">
      All Overwatch content, trademarks, and logos are © Blizzard Entertainment, Inc. 
      Team logos and player images are property of their respective owners.
      <br/>
      Hero imagery and event photography are sourced via Flickr and utilized under the 
      respective photographer's Creative Commons licensing. No copyright infringement is intended.
    </p>
      
      <p class="text-neutral-600 text-[9px] md:text-[10px] leading-relaxed font-mono uppercase pt-4 border-t border-white/5">
        Data provided by the <a href="https://liquipedia.net/api" class="text-neutral-300 hover:text-white transition-colors underline decoration-white/10 underline-offset-4">Official Liquipedia API</a>. 
        Tournament details and imagery are used under the 
        <a href="https://creativecommons.org/licenses/by-sa/3.0/" class="text-neutral-300 hover:text-white transition-colors underline decoration-white/10 underline-offset-4">CC-BY-SA 3.0 license</a>.
      </p>
    </div>

  </div>
</footer>

  </body>
</html>