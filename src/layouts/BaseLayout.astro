---
// src/layouts/BaseLayout.astro
import "../styles/global.css"; // <-- THIS IS THE CRITICAL LINE
import { ClientRouter } from "astro:transitions";
import SpeedInsights from "@vercel/speed-insights/astro";
import Image from "astro/components/Image.astro";
export interface Props {
    title: string;
}
const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <title>{title} | OWCS Nexus</title>
        <meta name="generator" content={Astro.generator} />
        <ClientRouter />
        <link
            rel="preload"
            href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css"
            as="style"
            onload="this.onload=null;this.rel='stylesheet'"
        />
        <link rel="manifest" href="/manifest.webmanifest" />
        <meta name="theme-color" content="#dc2626" />
        <meta name="apple-mobile-web-app-capable" content="yes" />
        <meta
            name="apple-mobile-web-app-status-bar-style"
            content="black-translucent"
        />
    </head>

    <body class="bg-neutral-950 text-gray-200">
        <SpeedInsights />
        {/* Header for the "OWCS Wiki" title */}
        <header
            class="absolute top-0 left-0 w-full py-8 z-50 bg-gradient-to-b from-black/80 to-transparent"
        >
            <div
                class="max-w-7xl mx-auto px-4 flex items-center justify-between"
            >
                {/* Changed to justify-between */}

                {
                    /* Left: Empty div or Links (to balance the center logo if needed) */
                }
                <div class="w-32 hidden md:block"></div>

                {/* Center: Logo */}
                <a href="/" class="block hover:opacity-80 transition-opacity">
                    <Image
                        src="/nexus_logo.png"
                        width={85}
                        height={48}
                        alt="OWCS Nexus"
                        class="h-12 w-auto"
                    />
                </a>

                {/* Right: Search Bar */}
                <div class="flex items-center justify-end w-auto min-w-[140px]">
                </div>
            </div>
        </header>

        <main>
            <slot />
        </main>

        <footer class="mt-10 py-10 border-t border-white/5">
            <div
                class="max-w-[1600px] mx-auto px-6 opacity-30 hover:opacity-100 transition-opacity duration-500"
            >
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6 items-start">
                    <!-- Col 1: Project disclaimer + contact -->
                    <p
                        class="font-mono text-[9px] uppercase tracking-tighter leading-relaxed text-white/70"
                    >
                        OWCS Nexus is an unofficial fan project. Not affiliated
                        with Blizzard Entertainment or the Overwatch Champions
                        Series. For inquiries and questions, find me on Twitter
                        at
                        <a
                            href="https://twitter.com/asheonetrick"
                            class="underline decoration-[#085FFF] hover:text-white transition-colors"
                        >
                            @asheonetrick
                        </a>
                    </p>

                    <!-- Col 2: Copyright -->
                    <p
                        class="font-mono text-[9px] uppercase tracking-tighter leading-relaxed text-white/70 md:text-center"
                    >
                        All Overwatch content, trademarks, and logos are ©
                        Blizzard Entertainment, Inc. Player imagery via Flickr /
                        Creative Commons and official OWCS media.
                    </p>

                    <!-- Col 3: Data attribution -->
                    <p
                        class="font-mono text-[9px] uppercase tracking-tighter leading-relaxed text-white/70 md:text-right"
                    >
                        Data provided by
                        <a
                            href="#"
                            class="underline decoration-[#085FFF] hover:text-white transition-colors"
                        >
                            Official Liquipedia API
                        </a>
                        <br />CC-BY-SA 3.0 License
                    </p>
                </div>
            </div>
        </footer>
    </body>
</html>
